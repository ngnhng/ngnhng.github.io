---
import BaseLayout from '../layouts/BaseLayout.astro'
import PostCard from '../components/PostCard.astro'
import SiteHeader from '../components/SiteHeader.astro'
import { featuredLinks, siteConfig } from '../data/site'
import { getBlogPosts, getNotes } from '../lib/content'

const blogPosts = await getBlogPosts({ includeDrafts: true })
const notes = await getNotes({ includeDrafts: true })
const publishedBlogPosts = blogPosts.filter(post => !post.data.draft)
---

<BaseLayout>
  <SiteHeader home tagline={siteConfig.description} />

  <main class="content">
    <section class="bio">
      <h1>Hi, I'm Nhật Nguyên.</h1>
      <p>
        I build minimal systems and write to clarify what I learn. This site is moving from
        hand-authored static HTML into an Astro and Lit setup that stays as small as possible while
        being easier to maintain.
      </p>
      <p>
        <a href={siteConfig.social.linkedin}>LinkedIn</a>
        ·
        <a href={siteConfig.social.github}>GitHub</a>
        ·
        <a href="/resume/">Resume</a>
      </p>
    </section>

    <section class="library">
      <h2>Featured</h2>
      <ul class="post-list">
        {featuredLinks.map(link => (
          <li class="post-card">
            <a href={link.href}>{link.label}</a>
            <span class="post-meta">{link.meta}</span>
          </li>
        ))}
      </ul>
    </section>

    <section class="library">
      <div class="section-heading">
        <h2>Blog</h2>
        <a class="section-link" href="/blog/">View archive</a>
      </div>
      <ul class="post-list">
        {blogPosts.map(entry => (
          <PostCard entry={entry} />
        ))}
      </ul>
    </section>

    <section class="library">
      <div class="section-heading">
        <h2>Notes</h2>
        <a class="section-link" href="/notes/">Browse notes</a>
      </div>
      <ul class="post-list">
        {notes.map(entry => (
          <PostCard entry={entry} />
        ))}
      </ul>
    </section>

    <section class="library">
      <h2>Feed</h2>
      <p>
        <a href="/rss.xml">Subscribe via RSS</a> to published blog posts.
      </p>
      <p class="post-meta">{publishedBlogPosts.length} published blog post(s) in the current migration.</p>
    </section>
  </main>
</BaseLayout>
