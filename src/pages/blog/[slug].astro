---
import { getCollection, render } from 'astro:content'
import PostLayout from '../../layouts/PostLayout.astro'

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft)
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }))
}

const { post } = Astro.props
const { Content, headings } = await render(post)
const relatedPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter(candidate => candidate.id !== post.id)
  .filter(candidate => candidate.data.tags.some(tag => post.data.tags.includes(tag)))
  .sort((left, right) => right.data.pubDate.getTime() - left.data.pubDate.getTime())
  .slice(0, 3)
  .map(candidate => ({
    href: `/blog/${candidate.id}/`,
    label: candidate.data.title,
    meta: candidate.data.pubDate.toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    }),
  }))
---

<PostLayout entry={post} headings={headings} relatedLinks={relatedPosts}>
  <Content />
</PostLayout>
