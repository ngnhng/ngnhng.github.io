---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { featuredLinks, siteConfig } from "../data/site";

interface HeadingLink {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedLink {
  href: string;
  label: string;
  meta: string;
}

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"notes">;
  headings?: HeadingLink[];
  relatedLinks?: RelatedLink[];
}

const { entry, headings = [], relatedLinks = [] } = Astro.props;
const title = `${entry.data.title} — Nhat-Nguyen`;
const artifactUrl =
  "artifactUrl" in entry.data ? entry.data.artifactUrl : undefined;
const pdfUrl = "pdfUrl" in entry.data ? entry.data.pdfUrl : undefined;
const sidebarLinks = [
  ...relatedLinks,
  ...featuredLinks.filter(
    (link) => link.href !== `/${entry.collection}/${entry.id}/`,
  ),
].slice(0, 4);
---

<BaseLayout title={title} description={entry.data.description}>
  <div class="post-site-header">
    <SiteHeader tagline="Notes on building calm systems." />
  </div>
  <main class="content post-shell">
    <article class="post">
      <header class="post-header post-card">
        <p class="eyebrow">{entry.collection === "blog" ? "Blog" : "Note"}</p>
        <h1>{entry.data.title}</h1>
        <p class="post-meta">
          Published {
            entry.data.pubDate.toLocaleDateString("en-US", {
              year: "numeric",
              month: "long",
              day: "numeric",
            })
          }
        </p>
        <p class="post-summary">{entry.data.description}</p>
        {
          (artifactUrl || pdfUrl) && (
            <div class="post-actions">
              {artifactUrl && (
                <a class="post-action" href={artifactUrl}>
                  Open deck
                </a>
              )}
              {pdfUrl && (
                <a class="post-action" href={pdfUrl}>
                  Download PDF
                </a>
              )}
            </div>
          )
        }
      </header>
      {
        headings.length > 0 && (
          <nav class="mobile-toc" aria-label="Mobile table of contents">
            <div class="mobile-toc__label">On this page</div>
            <ol class="mobile-toc__list">
              {headings
                .filter((heading) => heading.depth <= 3)
                .map((heading) => (
                  <li class={`toc-depth-${heading.depth}`}>
                    <a
                      href={`#${heading.slug}`}
                      data-toc-link
                      data-heading-id={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
            </ol>
          </nav>
        )
      }
      <div class="post-card post-content">
        <slot />
      </div>
    </article>
    <aside class="post-sidebar" aria-label="Article sidebar">
      <section class="sidebar-card sidebar-card--compact">
        <div class="sidebar-icon-links" aria-label="Personal links">
          <a href={siteConfig.social.github} aria-label="GitHub" title="GitHub">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M12 2C6.48 2 2 6.58 2 12.22c0 4.5 2.87 8.32 6.84 9.66.5.1.68-.22.68-.5 0-.24-.01-1.04-.02-1.88-2.78.62-3.37-1.2-3.37-1.2-.46-1.2-1.11-1.51-1.11-1.51-.91-.64.07-.63.07-.63 1 .08 1.54 1.06 1.54 1.06.9 1.58 2.36 1.13 2.94.86.09-.67.35-1.13.63-1.39-2.22-.26-4.56-1.14-4.56-5.08 0-1.12.39-2.03 1.03-2.75-.1-.26-.45-1.3.1-2.72 0 0 .84-.28 2.75 1.05A9.3 9.3 0 0 1 12 6.84c.85 0 1.71.12 2.5.36 1.9-1.33 2.74-1.05 2.74-1.05.56 1.42.21 2.46.1 2.72.64.72 1.03 1.63 1.03 2.75 0 3.95-2.34 4.82-4.57 5.08.36.32.68.94.68 1.9 0 1.38-.01 2.49-.01 2.83 0 .28.18.61.69.5A10.24 10.24 0 0 0 22 12.22C22 6.58 17.52 2 12 2Z"
              ></path>
            </svg>
          </a>
          <a
            href={siteConfig.social.linkedin}
            aria-label="LinkedIn"
            title="LinkedIn"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.4a1.56 1.56 0 0 1 0 3.1ZM5.6 18.4h2.68V9.64H5.6V18.4Zm4.37 0h2.67v-4.88c0-1.28.24-2.52 1.78-2.52 1.52 0 1.54 1.42 1.54 2.6v4.8H18.63v-5.34c0-2.63-.56-4.65-3.63-4.65-1.48 0-2.47.83-2.88 1.61h-.04V9.64H9.97c.03.9 0 8.76 0 8.76Z"
              ></path>
            </svg>
          </a>
          <a href="/resume/" aria-label="Resume" title="Resume">
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path
                d="M7 3.5h6.5L18 8v12.5H7V3.5Zm7 1.6v3.4h3.35L14 5.1ZM9 10h6v1.5H9V10Zm0 3h6v1.5H9V13Zm0 3h4.5v1.5H9V16Z"
              ></path>
            </svg>
          </a>
        </div>
      </section>

      {
        headings.length > 0 && (
          <section class="sidebar-card sidebar-card--toc">
            <p class="sidebar-kicker">Navigate</p>
            <nav class="toc" aria-label="Table of contents">
              <ol>
                {headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <li class={`toc-depth-${heading.depth}`}>
                      <a
                        href={`#${heading.slug}`}
                        data-toc-link
                        data-heading-id={heading.slug}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
              </ol>
            </nav>
          </section>
        )
      }

      {
        sidebarLinks.length > 0 && (
          <section class="sidebar-card">
            <p class="sidebar-kicker">Keep reading</p>
            <ul class="sidebar-list">
              {sidebarLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                  <p>{link.meta}</p>
                </li>
              ))}
            </ul>
          </section>
        )
      }
    </aside>
  </main>
</BaseLayout>

<style>
  .post-shell {
    width: min(100%, 96rem);
    margin: 0 auto;
    display: grid;
    gap: 2rem;
    align-items: start;
  }

  .post-site-header :global(.site-header) {
    width: min(100%, 96rem);
    margin: 0 auto 1.25rem;
  }

  .post {
    min-width: 0;
  }

  .post-card,
  .sidebar-card {
    border: 1px solid var(--base02);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--base01) 92%, transparent),
        var(--base01)
      ),
      var(--base00);
  }

  .post-header,
  .post-content,
  .sidebar-card {
    padding: clamp(1.25rem, 2vw, 2rem);
  }

  .post-content {
    margin-top: 1.25rem;
    min-width: 0;
  }

  .mobile-toc {
    position: sticky;
    top: 0.75rem;
    z-index: 5;
    margin-top: 1rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--base02);
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--base01) 94%, transparent),
        var(--base01)
      ),
      var(--base00);
    backdrop-filter: blur(10px);
  }

  .mobile-toc__label {
    margin-bottom: 0.65rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .mobile-toc__list {
    list-style: none;
    display: flex;
    gap: 0.65rem;
    margin: 0;
    padding: 0 0 0.2rem;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
  }

  .mobile-toc__list::-webkit-scrollbar {
    display: none;
  }

  .mobile-toc :global(li) {
    padding-left: 0;
    flex: 0 0 auto;
  }

  .mobile-toc a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.35rem 0.7rem;
    border: 1px solid var(--base02);
    color: var(--base04);
    background: color-mix(in srgb, var(--base01) 82%, transparent);
    white-space: nowrap;
    transition:
      color 160ms ease,
      border-color 160ms ease,
      background-color 160ms ease;
  }

  .mobile-toc a::before {
    display: none;
  }

  .mobile-toc a.is-active {
    color: var(--base07);
    border-color: var(--base0D);
    background: color-mix(in srgb, var(--base0D) 18%, var(--base01));
    transform: none;
  }

  .post-header h1 {
    margin: 0 0 0.75rem;
    font-size: clamp(1.65rem, 3vw, 2.5rem);
    line-height: 1.14;
  }

  .post-summary {
    max-width: 50rem;
    font-size: 1rem;
  }

  .post-sidebar {
    display: grid;
    gap: 1.5rem;
    align-content: start;
    align-self: start;
  }

  .sidebar-card {
    position: relative;
    height: fit-content;
  }

  .sidebar-kicker {
    margin: 0 0 0.75rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .sidebar-card h2 {
    margin: 0 0 1rem;
    font-size: 1.25rem;
    text-decoration-thickness: 1px;
  }

  .sidebar-list p,
  .toc a {
    font-size: 1rem;
  }

  .sidebar-icon-links {
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 0.85rem;
  }

  .sidebar-icon-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--base02);
    color: var(--base05);
    background: color-mix(in srgb, var(--base01) 78%, transparent);
  }

  .sidebar-icon-links a:hover,
  .sidebar-icon-links a:focus-visible {
    color: var(--base07);
    background: color-mix(in srgb, var(--base02) 84%, transparent);
    text-decoration: none;
  }

  .sidebar-icon-links svg {
    width: 1.15rem;
    height: 1.15rem;
    fill: currentColor;
  }

  .toc ol,
  .sidebar-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }

  .toc-depth-3 {
    padding-left: 1rem;
  }

  .toc a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--base04);
    transition:
      color 160ms ease,
      transform 160ms ease;
  }

  .toc a::before {
    content: "";
    width: 0.45rem;
    height: 0.45rem;
    border: 1px solid var(--base03);
    border-radius: 999px;
    background: transparent;
    flex: 0 0 auto;
    transition:
      border-color 160ms ease,
      background-color 160ms ease,
      transform 160ms ease;
  }

  .toc a:hover,
  .toc a:focus-visible {
    color: var(--base06);
    text-decoration: none;
  }

  .toc a.is-active {
    color: var(--base07);
    transform: translateX(0.15rem);
  }

  .toc a.is-active::before {
    border-color: var(--base0D);
    background: var(--base0D);
    transform: scale(1.1);
  }

  .sidebar-list li {
    display: grid;
    gap: 0.25rem;
  }

  .sidebar-list p {
    margin: 0;
    color: var(--base03);
  }

  .post-content :global(:first-child) {
    margin-top: 0;
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    margin-top: 2.5rem;
  }

  .post-content :global(figcaption) {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    color: var(--base03);
  }

  @media (min-width: 72rem) {
    .post-shell {
      grid-template-columns: minmax(0, 1.65fr) minmax(18rem, 0.55fr);
    }

    .mobile-toc {
      display: none;
    }

    .post-sidebar {
      position: sticky;
      top: 2rem;
    }
  }

  @media (max-width: 71.99rem) {
    .post-shell {
      gap: 1.25rem;
    }

    .post-site-header :global(.site-header) {
      margin-bottom: 1rem;
    }

    .post-content {
      margin-top: 0.75rem;
      padding: 1rem;
    }

    .sidebar-card--toc {
      display: none;
    }

    .sidebar-card--compact {
      order: -1;
    }
  }
</style>

<script is:inline>
  const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
  const headings = tocLinks
    .map((link) => {
      const id = link.getAttribute("data-heading-id");
      if (!id) return null;
      return {
        id,
        link,
        element: document.getElementById(id),
      };
    })
    .filter((item) => item && item.element);

  if (headings.length > 0) {
    let activeId = headings[0].id;

    const updateActiveLink = (id) => {
      if (!id || id === activeId) return;
      activeId = id;
      for (const heading of headings) {
        heading.link.classList.toggle("is-active", heading.id === activeId);
        if (heading.id === activeId)
          heading.link.setAttribute("aria-current", "true");
        else heading.link.removeAttribute("aria-current");
      }

      const activeLinks = headings
        .filter((heading) => heading.id === activeId)
        .map((heading) => heading.link);

      for (const link of activeLinks) {
        const mobileList = link.closest(".mobile-toc__list");
        if (mobileList) {
          link.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
            inline: "center",
          });
        }
      }
    };

    updateActiveLink(activeId);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (left, right) =>
              left.boundingClientRect.top - right.boundingClientRect.top,
          );

        if (visible.length > 0) {
          updateActiveLink(visible[0].target.id);
        }
      },
      {
        rootMargin: "-25% 0px -60% 0px",
        threshold: [0, 1],
      },
    );

    for (const heading of headings) observer.observe(heading.element);

    const syncFromScroll = () => {
      const passed = headings.filter(
        (heading) => heading.element.getBoundingClientRect().top <= 140,
      );
      const current = passed.at(-1) ?? headings[0];
      updateActiveLink(current.id);
    };

    window.addEventListener("scroll", syncFromScroll, { passive: true });
    window.addEventListener("hashchange", () =>
      updateActiveLink(window.location.hash.slice(1)),
    );
    syncFromScroll();
  }
</script>
