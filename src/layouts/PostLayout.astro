---
import type { CollectionEntry } from "astro:content";
import BaseLayout from "./BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";

interface HeadingLink {
  depth: number;
  slug: string;
  text: string;
}

interface RelatedLink {
  href: string;
  label: string;
  meta: string;
}

interface Props {
  entry: CollectionEntry<"blog"> | CollectionEntry<"notes">;
  headings?: HeadingLink[];
  relatedLinks?: RelatedLink[];
}

const { entry, headings = [], relatedLinks = [] } = Astro.props;
const title = `${entry.data.title} — Nhat-Nguyen`;
const artifactUrl =
  "artifactUrl" in entry.data ? entry.data.artifactUrl : undefined;
const pdfUrl = "pdfUrl" in entry.data ? entry.data.pdfUrl : undefined;
const publishedLabel = entry.data.pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const updatedLabel = entry.data.updatedDate?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
const taxonomy =
  entry.collection === "blog"
    ? entry.data.tags
    : "topic" in entry.data
      ? [entry.data.topic]
      : [];
---

<BaseLayout title={title} description={entry.data.description}>
  <div class="post-site-header">
    <SiteHeader tagline="Notes on building calm systems." />
  </div>
  <main class="content post-shell">
    <article class="post">
      <header class="post-header">
        <div class="post-meta-stack">
          <p class="post-meta-line">Published {publishedLabel}</p>
          {
            updatedLabel && (
              <p class="post-meta-line">Updated {updatedLabel}</p>
            )
          }
        </div>
        <h1>{entry.data.title}</h1>
        {
          taxonomy.length > 0 && (
            <ul class="post-taxonomy" aria-label="Article topics">
              {taxonomy.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          )
        }
        <p class="post-summary">{entry.data.description}</p>
        {
          (artifactUrl || pdfUrl) && (
            <div class="post-actions">
              {artifactUrl && (
                <a class="post-action" href={artifactUrl}>
                  Open deck
                </a>
              )}
              {pdfUrl && (
                <a class="post-action" href={pdfUrl}>
                  Download PDF
                </a>
              )}
            </div>
          )
        }
      </header>
      {
        headings.length > 0 && (
          <nav class="mobile-toc" aria-label="Mobile table of contents">
            <div class="mobile-toc__label">On this page</div>
            <ol class="mobile-toc__list">
              {headings
                .filter((heading) => heading.depth <= 3)
                .map((heading) => (
                  <li class={`toc-depth-${heading.depth}`}>
                    <a
                      href={`#${heading.slug}`}
                      data-toc-link
                      data-heading-id={heading.slug}
                    >
                      {heading.text}
                    </a>
                  </li>
                ))}
            </ol>
          </nav>
        )
      }
      <div class="post-content">
        <slot />
      </div>
      {
        relatedLinks.length > 0 && (
          <footer class="post-footer">
            <p class="post-footer__label">Keep reading</p>
            <ul class="post-footer__list">
              {relatedLinks.map((link) => (
                <li>
                  <a href={link.href}>{link.label}</a>
                  <p>{link.meta}</p>
                </li>
              ))}
            </ul>
          </footer>
        )
      }
    </article>
    <aside class="post-sidebar" aria-label="Article sidebar">
      {
        headings.length > 0 && (
          <section class="sidebar-card sidebar-card--toc">
            <p class="sidebar-kicker">On this page</p>
            <nav class="toc" aria-label="Table of contents">
              <ol>
                {headings
                  .filter((heading) => heading.depth <= 3)
                  .map((heading) => (
                    <li class={`toc-depth-${heading.depth}`}>
                      <a
                        href={`#${heading.slug}`}
                        data-toc-link
                        data-heading-id={heading.slug}
                      >
                        {heading.text}
                      </a>
                    </li>
                  ))}
              </ol>
            </nav>
          </section>
        )
      }
    </aside>
  </main>
</BaseLayout>

<style>
  .post-shell {
    width: min(100%, 100rem);
    margin: 0 auto;
    display: grid;
    gap: clamp(2rem, 4vw, 4.5rem);
    align-items: start;
    padding-top: clamp(1rem, 2vw, 2rem);
    border-top: 1px solid color-mix(in srgb, var(--base02) 65%, transparent);
  }

  .post-site-header :global(.site-header) {
    width: min(100%, 100rem);
    margin: 0 auto 1.25rem;
  }

  .post {
    min-width: 0;
    max-width: 64rem;
  }

  .sidebar-card {
    background: transparent;
  }

  .post-content {
    min-width: 0;
  }

  .mobile-toc {
    position: sticky;
    top: 0.75rem;
    z-index: 5;
    margin: 2rem 0;
    padding: 0.85rem 0 0.95rem;
    border-block: 1px solid color-mix(in srgb, var(--base02) 65%, transparent);
    background: var(--base00);
  }

  .mobile-toc__label {
    margin-bottom: 0.65rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .mobile-toc__list {
    list-style: none;
    display: flex;
    gap: 0.65rem;
    margin: 0;
    padding: 0 0 0.2rem;
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scrollbar-width: none;
  }

  .mobile-toc__list::-webkit-scrollbar {
    display: none;
  }

  .mobile-toc :global(li) {
    padding-left: 0;
    flex: 0 0 auto;
  }

  .mobile-toc a {
    display: inline-flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.25rem 0;
    border: 0;
    color: var(--base04);
    background: transparent;
    white-space: nowrap;
    transition:
      color 160ms ease,
      opacity 160ms ease;
  }

  .mobile-toc a::before {
    content: "";
    width: 1.4rem;
    height: 1px;
    margin-right: 0.55rem;
    background: color-mix(in srgb, var(--base03) 70%, transparent);
    transition: background-color 160ms ease;
  }

  .mobile-toc a.is-active {
    color: var(--base07);
    opacity: 1;
  }

  .mobile-toc a.is-active::before {
    background: var(--base0D);
  }

  .post-header {
    display: grid;
    gap: 1rem;
    margin-bottom: 2.25rem;
  }

  .post-meta-stack {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1rem;
  }

  .post-meta-line {
    margin: 0;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .post-header h1 {
    margin: 0;
    font-family: "Plus Jakarta Sans", "Helvetica Neue", Arial, sans-serif;
    font-size: clamp(2rem, 4vw, 3.2rem);
    font-weight: 500;
    line-height: 1.06;
    letter-spacing: -0.03em;
    text-decoration: none;
    color: var(--base07);
  }

  .post-taxonomy {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem 1rem;
    margin: 0;
    padding: 0;
  }

  .post-taxonomy li {
    font-size: 0.98rem;
    color: var(--base0D);
  }

  .post-summary {
    max-width: 42rem;
    margin: 0;
    font-size: clamp(1.05rem, 1rem + 0.3vw, 1.2rem);
    line-height: 1.75;
    color: var(--base04);
  }

  .post-sidebar {
    align-content: start;
    align-self: start;
  }

  .sidebar-card {
    position: relative;
    height: fit-content;
    padding-left: 1.1rem;
    border-left: 1px solid color-mix(in srgb, var(--base02) 70%, transparent);
  }

  .sidebar-kicker {
    margin: 0 0 0.75rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .toc a {
    font-size: 0.88rem;
  }

  .toc ol,
  .post-footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.8rem;
  }

  .toc-depth-3 {
    padding-left: 0.7rem;
  }

  .toc a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    color: var(--base04);
    transition:
      color 160ms ease,
      opacity 160ms ease;
  }

  .toc a::before {
    content: "";
    width: 0.7rem;
    height: 1px;
    background: color-mix(in srgb, var(--base03) 70%, transparent);
    flex: 0 0 auto;
    transition: background-color 160ms ease;
  }

  .toc a:hover,
  .toc a:focus-visible {
    color: var(--base06);
    text-decoration: none;
  }

  .toc a.is-active {
    color: var(--base07);
    opacity: 1;
  }

  .toc a.is-active::before {
    background: var(--base0D);
  }

  .post-footer {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid color-mix(in srgb, var(--base02) 65%, transparent);
  }

  .post-footer__label {
    margin: 0 0 1rem;
    font-family: "JetBrains Mono", "Courier New", monospace;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--base03);
  }

  .post-footer__list li {
    display: grid;
    gap: 0.25rem;
  }

  .post-footer__list p {
    margin: 0;
    color: var(--base03);
    font-size: 0.98rem;
  }

  .post-content :global(:first-child) {
    margin-top: 0;
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    font-family: "Plus Jakarta Sans", "Helvetica Neue", Arial, sans-serif;
    font-weight: 500;
    letter-spacing: -0.02em;
    text-decoration: none;
    color: var(--base07);
  }

  .post-content :global(h2),
  .post-content :global(h3) {
    margin-top: 3rem;
  }

  .post-content :global(h2) {
    font-size: clamp(1.7rem, 1.45rem + 0.8vw, 2.1rem);
    line-height: 1.15;
  }

  .post-content :global(h3) {
    font-size: clamp(1.2rem, 1.05rem + 0.35vw, 1.45rem);
    line-height: 1.25;
  }

  .post-content :global(figcaption) {
    margin-top: 0.5rem;
    font-size: 0.95rem;
    color: var(--base03);
  }

  @media (min-width: 72rem) {
    .post-shell {
      grid-template-columns: minmax(0, 1fr) minmax(11rem, 14rem);
    }

    .mobile-toc {
      display: none;
    }

    .post-sidebar {
      position: sticky;
      top: 2rem;
    }
  }

  @media (max-width: 71.99rem) {
    .post-shell {
      gap: 1.25rem;
      border-top: 0;
      padding-top: 0.5rem;
    }

    .post-site-header :global(.site-header) {
      margin-bottom: 1rem;
    }

    .post-sidebar {
      display: none;
    }

    .post-header h1 {
      font-size: clamp(1.9rem, 8vw, 2.6rem);
    }
  }
</style>

<script is:inline>
  const tocLinks = Array.from(document.querySelectorAll("[data-toc-link]"));
  const headings = tocLinks
    .map((link) => {
      const id = link.getAttribute("data-heading-id");
      if (!id) return null;
      return {
        id,
        link,
        element: document.getElementById(id),
      };
    })
    .filter((item) => item && item.element);

  if (headings.length > 0) {
    let activeId = headings[0].id;

    const updateActiveLink = (id) => {
      if (!id || id === activeId) return;
      activeId = id;
      for (const heading of headings) {
        heading.link.classList.toggle("is-active", heading.id === activeId);
        if (heading.id === activeId)
          heading.link.setAttribute("aria-current", "true");
        else heading.link.removeAttribute("aria-current");
      }

      const activeLinks = headings
        .filter((heading) => heading.id === activeId)
        .map((heading) => heading.link);

      for (const link of activeLinks) {
        const mobileList = link.closest(".mobile-toc__list");
        if (mobileList) {
          link.scrollIntoView({
            behavior: "smooth",
            block: "nearest",
            inline: "center",
          });
        }
      }
    };

    updateActiveLink(activeId);

    const observer = new IntersectionObserver(
      (entries) => {
        const visible = entries
          .filter((entry) => entry.isIntersecting)
          .sort(
            (left, right) =>
              left.boundingClientRect.top - right.boundingClientRect.top,
          );

        if (visible.length > 0) {
          updateActiveLink(visible[0].target.id);
        }
      },
      {
        rootMargin: "-25% 0px -60% 0px",
        threshold: [0, 1],
      },
    );

    for (const heading of headings) observer.observe(heading.element);

    const syncFromScroll = () => {
      const passed = headings.filter(
        (heading) => heading.element.getBoundingClientRect().top <= 140,
      );
      const current = passed.at(-1) ?? headings[0];
      updateActiveLink(current.id);
    };

    window.addEventListener("scroll", syncFromScroll, { passive: true });
    window.addEventListener("hashchange", () =>
      updateActiveLink(window.location.hash.slice(1)),
    );
    syncFromScroll();
  }
</script>
